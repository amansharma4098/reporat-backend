# RepoRat Backend Configuration

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Repo Connectors
GITHUB_PAT=ghp_xxxxx
AZURE_DEVOPS_PAT=xxxxx
AZURE_DEVOPS_ORG=your-org
GITLAB_TOKEN=glpat-xxxxx

# Bug Tracker: Jira
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=xxxxx
JIRA_PROJECT_KEY=PROJ

# Bug Tracker: Azure DevOps Boards
AZURE_BOARDS_ORG=your-org
AZURE_BOARDS_PROJECT=your-project
AZURE_BOARDS_PAT=xxxxx

# Bug Tracker: GitHub Issues
GITHUB_ISSUES_PAT=ghp_xxxxx
GITHUB_ISSUES_REPO=owner/repo

# Bug Tracker: Linear
LINEAR_API_KEY=lin_api_xxxxx
LINEAR_TEAM_ID=xxxxx

# JWT / Auth
JWT_SECRET_KEY=your-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite+aiosqlite:///reporat.db

# Server
SCAN_TEMP_DIR=/tmp/reporat
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://reporat.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
