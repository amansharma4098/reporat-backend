# RepoRat Backend Configuration

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reporat

# JWT / Auth
JWT_SECRET_KEY=change-this-run-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# CORS
CORS_ORIGINS=http://localhost:3000

# Repo Connectors
GITHUB_PAT=ghp_xxxxx
AZURE_DEVOPS_PAT=xxxxx
AZURE_DEVOPS_ORG=your-org
GITLAB_TOKEN=glpat-xxxxx

# Bug Tracker: Jira
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=xxxxx
JIRA_PROJECT_KEY=PROJ

# Bug Tracker: Azure DevOps Boards
AZURE_BOARDS_ORG=your-org
AZURE_BOARDS_PROJECT=your-project
AZURE_BOARDS_PAT=xxxxx

# Bug Tracker: GitHub Issues
GITHUB_ISSUES_PAT=ghp_xxxxx
GITHUB_ISSUES_REPO=owner/repo

# Bug Tracker: Linear
LINEAR_API_KEY=lin_api_xxxxx
LINEAR_TEAM_ID=xxxxx

# Server
SCAN_TEMP_DIR=/tmp/reporat
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3000
